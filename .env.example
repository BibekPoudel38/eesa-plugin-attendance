# Eesa platform JWKS + issuer (must match the platform).
EESA_JWKS_URL=https://eesa.ai/.well-known/jwks.json
EESA_TOKEN_ISSUER=eesa
# Shared gateway secret — applies to the /mcp surface only. The /api hot path is
# called directly by the app and is authenticated by the token alone.
PLUGIN_GATEWAY_SECRET=
# Supabase Postgres connection string (Project → Settings → Database).
DATABASE_URL=postgres://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
PGSSL=require
PORT=8080
